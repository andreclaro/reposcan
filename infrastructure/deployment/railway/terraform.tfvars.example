# =============================================================================
# Railway Terraform Variables - Example
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git (it's in .gitignore)
# =============================================================================

# Railway API Token (required)
# Get yours from: https://railway.app/account/tokens
# Or set via environment variable: export RAILWAY_TOKEN="your_token"
railway_token = "your-railway-api-token-here"

# Project Configuration
project_name = "securitykit"
environment  = "production"

# GitHub Repository
github_repo   = "https://github.com/yourusername/sec-audit-repos"
github_branch = "main"

# Custom Domains (optional)
# custom_domain = "app.yourdomain.com"
# api_domain    = "api.yourdomain.com"
