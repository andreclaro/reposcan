# Go API Backend (deployed on Hetzner K8s)
# This is used by Next.js server-side API routes to proxy requests
# For local dev: http://localhost:8000
# For production: https://api.yourdomain.com
FASTAPI_BASE_URL=http://localhost:8000

# Public API URL (used by browser for direct connections if needed)
# Should match FASTAPI_BASE_URL in production
NEXT_PUBLIC_API_URL=http://localhost:8000

# GitHub App Configuration (for private repository access)
# Create at: https://github.com/settings/apps
# This is separate from the OAuth App used for authentication
# GITHUB_APP_ID=123456
# GITHUB_APP_NAME=securitykit
# GITHUB_APP_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
# GITHUB_APP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Server-side GitHub token for public repo scanning
# This is used as a fallback for higher API rate limits
# GITHUB_TOKEN=ghp_...

# Database Configuration
# PostgreSQL connection string for Next.js app
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sec_audit

# Authentication Configuration (NextAuth.js v5)
# GitHub OAuth app credentials
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret
# Secret for encrypting session tokens (generate with: openssl rand -base64 32)
AUTH_SECRET=replace_with_random_secret
# Base URL for auth callbacks (optional, auto-detected if not set)
# AUTH_URL=http://localhost:3003/api/auth
DEV_BYPASS_AUTH=false

# Admin Access (comma-separated list of admin emails)
ADMIN_EMAIL=admin@example.com

# Beta Mode: when true, new user accounts are disabled by default and require admin approval
BETA_MODE_ENABLED=false

# Email (Resend) - used for contact form and transactional emails
# RESEND_API_KEY=re_...
# RESEND_FROM=SecureFast <onboarding@resend.dev>  # Use resend.dev until your domain is verified in Resend
# CONTACT_EMAIL=contact@securitykit.io  # Recipient for contact form (default: contact@securitykit.io)
# NEXT_PUBLIC_CONTACT_EMAIL=contact@yourcompany.com  # Fallback recipient if CONTACT_EMAIL unset

# App branding (used in emails)
# APP_NAME=SecurityKit
# APP_URL=https://securitykit.io  # Used for email links and redirects

# Stripe (billing)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PUBLISHABLE_KEY=pk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Logging (server: API routes; client: browser console)
# Levels: error | warn | info | debug | silent. Default: warn. Use debug for verbose logs.
LOG_LEVEL=warn
NEXT_PUBLIC_LOG_LEVEL=warn

# AI Analysis UI: when true, show AI Analysis tab and admin Generate/Regenerate. When false, hide all AI analysis UI.
# Worker still needs AI_ANALYSIS_ENABLED + API key to run analysis; this only controls visibility in the frontend.
AI_ANALYSIS_ENABLED=false
# See ../.env.example for AI_PROVIDER, AI_MODEL, KIMI_API_KEY, ANTHROPIC_API_KEY, etc. (worker env)
