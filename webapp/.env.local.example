# FastAPI Backend
FASTAPI_BASE_URL=http://localhost:8000

# Optional: GitHub API token for resolving branch to commit (enables existing-scan reuse without cloning)
# GITHUB_TOKEN=ghp_...

# Database Configuration
# PostgreSQL connection string for Next.js app
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sec_audit

# Authentication Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
NEXTAUTH_SECRET=replace_with_random_secret
DEV_BYPASS_AUTH=false

# Admin Access (comma-separated list of admin emails)
ADMIN_EMAIL=admin@example.com

# Logging (server: API routes; client: browser console)
# Levels: error | warn | info | debug | silent. Default: warn. Use debug for verbose logs.
LOG_LEVEL=warn
NEXT_PUBLIC_LOG_LEVEL=warn

# Note: AI analysis and storage configuration is handled by the Python worker
# See ../.env.example for AI_PROVIDER, AI_MODEL, ANTHROPIC_API_KEY, etc.
