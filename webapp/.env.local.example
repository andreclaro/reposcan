# FastAPI Backend
FASTAPI_BASE_URL=http://localhost:8000

# Optional: GitHub API token for resolving branch to commit (enables existing-scan reuse without cloning)
# GITHUB_TOKEN=ghp_...

# Database Configuration
# PostgreSQL connection string for Next.js app
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sec_audit

# Authentication Configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
NEXTAUTH_SECRET=replace_with_random_secret
# Base URL for auth redirects. Use http://localhost:3000 for local dev (omit to use request host).
NEXTAUTH_URL=http://localhost:3000
DEV_BYPASS_AUTH=false

# Admin Access (comma-separated list of admin emails)
ADMIN_EMAIL=admin@example.com

# Beta Mode: when true, new user accounts are disabled by default and require admin approval
BETA_MODE_ENABLED=false

# Contact form (Resend)
# RESEND_API_KEY=re_...
# RESEND_FROM=SecurityKit <onboarding@resend.dev>  # Must be verified domain in Resend
# CONTACT_EMAIL=contact@securitykit.io  # Recipient for contact form (default: contact@securitykit.io)
# NEXT_PUBLIC_CONTACT_EMAIL=contact@yourcompany.com  # Fallback recipient if CONTACT_EMAIL unset

# Stripe (billing)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PUBLISHABLE_KEY=pk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Logging (server: API routes; client: browser console)
# Levels: error | warn | info | debug | silent. Default: warn. Use debug for verbose logs.
LOG_LEVEL=warn
NEXT_PUBLIC_LOG_LEVEL=warn

# AI Analysis UI: when true, show AI Analysis tab and admin Generate/Regenerate. When false, hide all AI analysis UI.
# Worker still needs AI_ANALYSIS_ENABLED + API key to run analysis; this only controls visibility in the webapp.
AI_ANALYSIS_ENABLED=false
# See ../.env.example for AI_PROVIDER, AI_MODEL, KIMI_API_KEY, ANTHROPIC_API_KEY, etc. (worker env)
