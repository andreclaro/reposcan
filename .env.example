# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Results Storage
RESULTS_DIR=./results

# Database Configuration (for Python worker)
# PostgreSQL connection string for storing findings and AI analysis
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sec_audit

# Storage Backend Configuration
# Options: "local", "s3", or "none"
# - "local": Store files in local filesystem (default)
# - "s3": Store files in S3-compatible storage
# - "none": Skip file storage
STORAGE_BACKEND=local

# Local Storage Configuration (when STORAGE_BACKEND=local)
STORAGE_BASE_PATH=./results

# S3 Storage Configuration (when STORAGE_BACKEND=s3)
S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# Optional: For S3-compatible services (e.g., MinIO, DigitalOcean Spaces)
# S3_ENDPOINT_URL=https://s3.amazonaws.com

# AI Analysis Configuration
# Enable/disable AI-powered analysis (default: false)
AI_ANALYSIS_ENABLED=false

# AI Provider Configuration
# Options: "anthropic" or "openai" (default: anthropic)
AI_PROVIDER=anthropic

# AI Model Selection
# For Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
# For OpenAI: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
AI_MODEL=claude-3-opus-20240229

# AI API Keys (at least one required if AI_ANALYSIS_ENABLED=true)
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
